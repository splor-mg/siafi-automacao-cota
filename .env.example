# Credenciais de acesso ao SIAFI
SISTEMA=SIAF
USUARIO=seu_login_siafi
SENHA=sua_senha_siafi
UNIDADE_EXECUTORA=1451

# Caminho WSL até a pasta-raiz do projeto de cotas no OneDrive
# (diretório que contém as subpastas "Robo (IPU 2)", "Realizados", "Conferencia arquivo robo", etc.)
# Substitua SEU_USUARIO pelo seu nome de usuário Windows
# Exemplo: /mnt/c/Users/SEU_USUARIO/OneDrive - CAMG/General/@dcmefo/2026/Robo - Remanejamento e aprovacao de cota
ONEDRIVE_BASE=/mnt/c/Users/SEU_USUARIO/OneDrive - CAMG/General/@dcmefo/2026/Robo - Remanejamento e aprovacao de cota

# Pasta local (Linux/WSL) para cópia temporária dos arquivos durante a execução
# O robô copia o Excel aqui para não depender da sincronização do OneDrive enquanto processa
# Exemplo: /home/SEU_USUARIO_LINUX/code/splor-mg/siafi-automacao-cota/data
PASTA_LOCAL=/home/SEU_USUARIO_LINUX/siafi-trabalho

# Servidor SIAFI (padrão: bhmvsb.prodemge.gov.br)
# Altere apenas se for necessário usar um ambiente diferente (ex: homologação)
SIAFI_HOST=bhmvsb.prodemge.gov.br

# Exibir a janela gráfica do x3270 durante a execução (true/false)
# Requer WSLg (Windows 11). Use false para rodar sem interface gráfica
SIAFI_VISIVEL=true

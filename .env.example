# Credenciais de acesso ao SIAFI
SISTEMA=SIAF
USUARIO=seu_login_siafi
SENHA=sua_senha_siafi
UNIDADE_EXECUTORA=1451

# Caminho WSL até a pasta-raiz do projeto de cotas no OneDrive
# (diretório que contém as subpastas "Robo (IPU 2)", "Realizados", "Conferencia arquivo robo", etc.)
# Substitua SEU_USUARIO pelo seu nome de usuário Windows
ONEDRIVE_BASE=/mnt/c/Users/SEU_USUARIO/OneDrive - CAMG/@splor/@dcmefo/2026/Robo - Remanejamento e aprovacao de cota

# Pasta local (Linux/WSL) para cópia temporária dos arquivos durante a execução
# O robô copia o Excel aqui para não depender da sincronização do OneDrive enquanto processa
PASTA_LOCAL=/home/SEU_USUARIO_LINUX/siafi-trabalho
